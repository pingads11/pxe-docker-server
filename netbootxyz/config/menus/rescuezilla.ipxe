#!ipxe

# Rescuezilla Disk imaging
# https://rescuezilla.com/

:rescuezilla
set os Rescuezilla
menu ${os} Live CD
item rescuezilla_2.6.1 ${space} ${os} 2.6.1
choose rescuezilla_version || goto rescuezilla_exit
goto ${rescuezilla_version}

:rescuezilla_2.6.1
set kernel_url ${live_endpoint}/asset-mirror/releases/download/2.6.1-123ed276/
imgfree
kernel ${kernel_url}vmlinuz ip=dhcp boot=casper netboot=url url=${kernel_url}filesystem.squashfs initrd=initrd.magic ${cmdline}
initrd ${kernel_url}initrd
boot

:rescuezilla_exit
clear menu
exit 0
